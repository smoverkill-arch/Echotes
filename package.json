{
  "name": "echotes",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "doc:guard": "docguard guard",
    "doc:score": "docguard score",
    "doc:diagnose": "docguard diagnose",
    "lint": "eslint .",
    "test": "jest --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "supabase:start": "node scripts/supabase-local.mjs start",
    "supabase:stop": "node scripts/supabase-local.mjs stop",
    "supabase:status": "supabase status",
    "supabase:doctor": "node scripts/supabase-local.mjs doctor",
    "db:local:reset": "supabase db reset --local",
    "db:migrations": "supabase migration list",
    "db:remote:dry-run": "supabase db push --dry-run",
    "db:remote:push": "supabase db push",
    "validate": "docguard guard && eslint . && jest --passWithNoTests && tsc --noEmit"
  },
  "dependencies": {
    "@babel/runtime": "^7.29.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@supabase/supabase-js": "^2.103.3",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1",
    "zod": "^4.1.12",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@expo/metro-config": "~54.0.14",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.6.0",
    "@types/react": "~19.1.0",
    "babel-preset-expo": "~54.0.10",
    "docguard-cli": "0.9.11",
    "eslint": "^9.18.0",
    "eslint-config-expo": "~10.0.0",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.17",
    "react-test-renderer": "19.1.0",
    "supabase": "^2.98.2",
    "typescript": "~5.9.2"
  }
}
